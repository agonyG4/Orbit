#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DEFAULT_UNIT_NAME="astrea-screentimed.service"
LEGACY_UNIT_NAME="astrea-screentimed-legacy.service"
USER_UNIT_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user"

restore_legacy() {
  mkdir -p "$USER_UNIT_DIR"
  ln -sf "$ROOT_DIR/$LEGACY_UNIT_NAME" "$USER_UNIT_DIR/$LEGACY_UNIT_NAME"
  systemctl --user import-environment HYPRLAND_INSTANCE_SIGNATURE WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_TYPE
  systemctl --user daemon-reload
  systemctl --user disable --now "$DEFAULT_UNIT_NAME" >/dev/null 2>&1 || true
  systemctl --user enable --now "$LEGACY_UNIT_NAME"
}

case "${1:-}" in
  restore-python|restore-legacy)
    restore_legacy
    ;;
  *)
    exec "$ROOT_DIR/bin/screentime-service" "$@"
    ;;
esac
